# ============================================
# Blueprint IA - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e configure os valores

# ============================================
# Ambiente
# ============================================
NODE_ENV=production

# ============================================
# Banco de Dados PostgreSQL
# ============================================
POSTGRES_USER=blueprint
POSTGRES_PASSWORD=sua_senha_segura_aqui
POSTGRES_DB=blueprint_ia

# URL completa para o Prisma (use esta OU as variáveis acima)
# Para Docker local:
DATABASE_URL=postgresql://blueprint:sua_senha_segura_aqui@postgres:5432/blueprint_ia?schema=public

# Para Azure Database for PostgreSQL:
# DATABASE_URL=postgresql://usuario@servidor:senha@servidor.postgres.database.azure.com:5432/blueprint_ia?schema=public&sslmode=require

# ============================================
# Autenticação JWT
# ============================================
# IMPORTANTE: Gere uma chave segura para produção
# Você pode usar: openssl rand -base64 64
JWT_SECRET=MUDE_ESTA_CHAVE_EM_PRODUCAO_use_openssl_rand_base64_64

# ============================================
# Configuração de Email (SMTP)
# ============================================
# Usado para enviar convites de avaliação
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app
SMTP_FROM=Blueprint IA <noreply@seudominio.com>

# URL pública do app (links nos e-mails: relatório diagnóstico rápido, convites). Em dev: http://localhost:5173
# BASE_URL=https://agentica.sysmap.com.br

# E-mail para solicitação do Assessment completo (mailto no diagnóstico rápido)
# ASSESSMENT_CONTACT_EMAIL=contato@sysmap.com.br

# ============================================
# Anthropic API (Claude) - Geração de Especificações
# ============================================
# Obtenha sua chave em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-sua_chave_aqui

# ============================================
# Docker Registry (para produção)
# ============================================
DOCKER_REGISTRY=blueprintia
TAG=latest

# ============================================
# Azure Container Registry (opcional)
# ============================================
# ACR_NAME=seuacr
# ACR_LOGIN_SERVER=seuacr.azurecr.io
