# ============================================
# Blueprint IA - Produção
# ============================================
# Domínio: https://agentica.sysmap.com.br
# IP do Servidor: 4.228.96.10 (back-end SSH/deploy)
# Porta: 443 (HTTPS)
#
# IMPORTANTE: Configure as senhas antes de fazer deploy!
# ============================================

# URL pública usada nos links dos e-mails (convite e resultado da avaliação).
# Deve ser o domínio com certificado SSL válido — nunca o IP.
BASE_URL=https://agentica.sysmap.com.br

# ============================================
# Ambiente
# ============================================
NODE_ENV=production

# ============================================
# Banco de Dados PostgreSQL
# ============================================
POSTGRES_USER=blueprint
POSTGRES_PASSWORD=SUA_SENHA_SEGURA_AQUI
POSTGRES_DB=blueprint_ia

# URL de conexão para Prisma (usa o container postgres)
DATABASE_URL=postgresql://blueprint:SUA_SENHA_SEGURA_AQUI@postgres:5432/blueprint_ia?schema=public

# ============================================
# Autenticação JWT
# ============================================
# GERE UMA CHAVE SEGURA: openssl rand -base64 64
JWT_SECRET=GERE_UMA_CHAVE_SEGURA_COM_OPENSSL

# ============================================
# Anthropic API (Claude) - Geração de Especificações
# ============================================
ANTHROPIC_API_KEY=sk-ant-sua_chave_aqui

# ============================================
# OpenAI API (GPT) - Alternativa para geração
# ============================================
# OPENAI_API_KEY=sk-sua_chave_aqui
# AI_PROVIDER=openai

# ============================================
# Configuração de Email (SMTP) - Opcional
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu_email@gmail.com
# SMTP_PASS=sua_senha_de_app
# SMTP_FROM=Blueprint IA <noreply@seudominio.com>

# ============================================
# Docker Registry
# ============================================
DOCKER_REGISTRY=blueprintia
TAG=latest
